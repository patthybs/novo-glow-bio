<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Glow Headspa & Beauty — Agende seu Ritual</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --slate:    #2B4A54;
    --slate-lt: #3D6270;
    --teal:     #4A8B8C;
    --teal-lt:  #C8E0E0;
    --sand:     #D4A97A;
    --sand-lt:  #F5EDE0;
    --terra:    #A0522D;
    --terra-lt: #FAECE7;
    --cream:    #F7F3EE;
    --white:    #FFFFFF;
    --text:     #1C1C1C;
    --muted:    #6B7280;
    --serif: 'Cormorant Garamond', Georgia, serif;
    --sans:  'DM Sans', sans-serif;
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body { font-family: var(--sans); background: var(--cream); color: var(--text); font-size: 16px; line-height: 1.6; -webkit-font-smoothing: antialiased; overflow-x: hidden; }
  img { display: block; max-width: 100%; }
  a { text-decoration: none; color: inherit; }

  .sticky-bar {
    position: fixed; bottom: 0; left: 0; right: 0; z-index: 100;
    background: var(--slate); padding: 14px 20px;
    display: flex; align-items: center; justify-content: space-between; gap: 12px;
    transform: translateY(100%); transition: transform 0.4s ease;
    box-shadow: 0 -4px 24px rgba(0,0,0,0.15);
  }
  .sticky-bar.visible { transform: translateY(0); }
  .sticky-bar-text { font-size: 13px; color: rgba(255,255,255,0.7); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .sticky-bar-btn {
    background: var(--sand); color: var(--slate); font-family: var(--sans);
    font-size: 13px; font-weight: 500; padding: 10px 22px; border-radius: 50px;
    border: none; cursor: pointer; white-space: nowrap; flex-shrink: 0; transition: all 0.2s;
  }
  .sticky-bar-btn:hover { background: #c49060; transform: scale(1.05); }

  header {
    background: var(--slate); padding: 18px 24px;
    display: flex; align-items: center; justify-content: space-between;
    position: relative; z-index: 10; box-shadow: 0 2px 12px rgba(0,0,0,0.08);
  }
  .logo { font-family: var(--serif); font-size: 22px; font-weight: 400; color: var(--white); letter-spacing: 0.18em; }
  .logo span { display: block; font-family: var(--sans); font-size: 9px; font-weight: 300; letter-spacing: 0.28em; color: var(--teal-lt); margin-top: 2px; }
  .header-link { font-size: 12px; color: rgba(255,255,255,0.55); letter-spacing: 0.04em; transition: all 0.3s; }
  .header-link:hover { color: var(--sand); transform: translateX(4px); }

  .hero {
    background: var(--slate); padding: 60px 24px 72px; text-align: center;
    position: relative; overflow: hidden; min-height: 520px;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
  }

  .hero-bg-mobile {
    position: absolute; inset: 0; width: 100%; height: 100%;
    overflow: hidden; pointer-events: none; z-index: 0;
    display: block;
  }
  .hero-bg-mobile iframe {
    width: 177.77vw;
    height: 100vh;
    min-width: 100vw;
    min-height: 56.25vw;
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    opacity: 0.8;
    border: none;
    pointer-events: none;
    filter: brightness(0.6);
  }

  .hero-bg-desktop {
    position: absolute; inset: 0; width: 100%; height: 100%;
    overflow: hidden; pointer-events: none; z-index: 0;
    display: none;
  }
  .hero-bg-desktop video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.8;
    filter: brightness(0.6);
  }

  .hero-overlay {
    position: absolute; inset: 0;
    background: rgba(43, 74, 84, 0.5);
    opacity: 1;
    z-index: 1;
    pointer-events: none;
  }
  .hero-content { position: relative; z-index: 2; width: 100%; }
  .hero::before { content: ''; position: absolute; top: -80px; right: -80px; width: 280px; height: 280px; border-radius: 50%; border: 1px solid rgba(200,224,224,0.1); pointer-events: none; z-index: 2; }
  .hero::after  { content: ''; position: absolute; bottom: -50px; left: -50px; width: 200px; height: 200px; border-radius: 50%; border: 1px solid rgba(212,169,122,0.1); pointer-events: none; z-index: 2; }
  .hero-eyebrow { font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--teal-lt); margin-bottom: 20px; opacity: 0; animation: fadeUp 0.7s 0.1s forwards; }
  .hero-title { font-family: var(--serif); font-size: clamp(38px, 9vw, 56px); font-weight: 300; color: var(--white); line-height: 1.12; margin-bottom: 20px; opacity: 0; animation: fadeUp 0.7s 0.2s forwards; }
  .hero-title em { font-style: italic; color: var(--sand); }
  .hero-sub { font-size: 15px; font-weight: 300; color: rgba(255,255,255,0.8); max-width: 360px; margin: 0 auto 36px; line-height: 1.7; opacity: 0; animation: fadeUp 0.7s 0.3s forwards; }
  .hero-cta {
    display: inline-block; background: var(--sand); color: var(--slate);
    font-family: var(--sans); font-size: 15px; font-weight: 500;
    padding: 17px 40px; border-radius: 50px; letter-spacing: 0.02em;
    transition: all 0.3s; opacity: 0; animation: fadeUp 0.7s 0.4s forwards;
    box-shadow: 0 8px 20px rgba(212, 169, 122, 0.25);
  }
  .hero-cta:hover { background: #c49060; transform: translateY(-3px); box-shadow: 0 12px 28px rgba(212, 169, 122, 0.35); }
  .hero-note { margin-top: 14px; font-size: 12px; color: rgba(255,255,255,0.5); opacity: 0; animation: fadeUp 0.7s 0.5s forwards; }

  .trust-bar {
    background: var(--sand-lt); padding: 20px 24px;
    display: flex; align-items: center; justify-content: center; gap: 24px; flex-wrap: wrap;
    border-bottom: 1px solid rgba(212,169,122,0.25);
  }
  .trust-item { display: flex; align-items: center; gap: 8px; font-size: 13px; color: var(--slate); font-weight: 500; }
  .trust-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--teal); flex-shrink: 0; box-shadow: 0 0 12px rgba(74, 139, 140, 0.4); }

  .container { max-width: 1400px; margin: 0 auto; padding: 0 24px; }

  section { padding: 60px 24px; }
  .section-label { font-size: 10px; letter-spacing: 0.24em; text-transform: uppercase; color: var(--teal); margin-bottom: 10px; font-weight: 500; }
  .section-title { font-family: var(--serif); font-size: clamp(30px, 7vw, 40px); font-weight: 300; color: var(--slate); line-height: 1.18; margin-bottom: 14px; }
  .section-title em { font-style: italic; color: var(--terra); }
  .section-body { font-size: 15px; color: var(--muted); line-height: 1.75; max-width: 500px; }

  .services { background: var(--white); }
  .services-grid { display: grid; grid-template-columns: 1fr; gap: 20px; margin-top: 40px; align-items: stretch; }
  .service-card {
    border: 1px solid rgba(43,74,84,0.1); border-radius: 20px; overflow: hidden;
    background: var(--cream); transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    display: flex; flex-direction: column; height: 100%;
    box-shadow: 0 4px 16px rgba(0,0,0,0.05);
    position: relative;
  }
  .service-card:hover { 
    transform: translateY(-8px); 
    box-shadow: 0 16px 40px rgba(43,74,84,0.12);
    border-color: rgba(43,74,84,0.2);
  }
  .service-card.featured { background: var(--slate); border-color: var(--slate); }
  .service-image {
    width: 100%; height: 240px; object-fit: cover; overflow: hidden;
    background: linear-gradient(135deg, var(--teal-lt), var(--sand-lt));
    position: relative;
  }
  .service-image img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s ease; }
  .service-card:hover .service-image img { transform: scale(1.08); }
  .service-content { padding: 26px; flex-grow: 1; display: flex; flex-direction: column; }
  .service-tag { display: inline-block; font-size: 10px; font-weight: 500; letter-spacing: 0.14em; text-transform: uppercase; padding: 6px 14px; border-radius: 50px; margin-bottom: 14px; }
  .tag-teal { background: var(--teal-lt); color: var(--slate); }
  .tag-terra { background: var(--terra-lt); color: var(--terra); }
  .tag-sand { background: var(--sand-lt); color: #7A5C3A; }
  .tag-white { background: rgba(255,255,255,0.14); color: var(--teal-lt); }
  .service-name { font-family: var(--serif); font-size: 23px; font-weight: 400; color: var(--slate); margin-bottom: 8px; line-height: 1.2; }
  .featured .service-name { color: var(--white); }
  .service-desc { font-size: 13px; color: var(--muted); line-height: 1.65; margin-bottom: 16px; }
  .featured .service-desc { color: rgba(255,255,255,0.6); }
  .service-features { list-style: none; margin-bottom: 18px; }
  .service-features li { font-size: 13px; color: var(--muted); padding: 5px 0; display: flex; align-items: flex-start; gap: 8px; border-bottom: 1px solid rgba(43,74,84,0.05); }
  .service-features li:last-child { border-bottom: none; }
  .featured .service-features li { color: rgba(255,255,255,0.65); border-bottom-color: rgba(255,255,255,0.07); }
  .service-features li::before { content: ''; width: 5px; height: 5px; border-radius: 50%; background: var(--teal); flex-shrink: 0; margin-top: 6px; }
  .featured .service-features li::before { background: var(--sand); }
  .service-btn {
    display: block; text-align: center; padding: 13px; border-radius: 50px;
    font-size: 13px; font-weight: 500; transition: all 0.2s; cursor: pointer; border: none; width: 100%;
    margin-top: auto;
  }
  .btn-dark { background: var(--slate); color: var(--white); }
  .btn-dark:hover { background: var(--slate-lt); transform: translateY(-2px); }
  .btn-sand { background: var(--sand); color: var(--slate); }
  .btn-sand:hover { background: #c49060; transform: translateY(-2px); }

  .sub-cards { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 18px; }
  .sub-card { background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; padding: 10px 12px; transition: all 0.2s; }
  .sub-card:hover { background: rgba(255,255,255,0.12); transform: translateY(-2px); }
  .sub-card-name { font-size: 12px; font-weight: 500; color: var(--white); margin-bottom: 2px; }
  .sub-card-price { font-size: 11px; color: var(--sand); }

  .sub-cards-light { display: grid; grid-template-columns: 1fr; gap: 8px; margin-bottom: 18px; }
  .sub-card-light { background: rgba(43,74,84,0.05); border: 1px solid rgba(43,74,84,0.08); border-radius: 10px; padding: 10px 12px; display: flex; justify-content: space-between; align-items: center; transition: all 0.2s; }
  .sub-card-light:hover { background: rgba(43,74,84,0.08); transform: translateX(4px); }
  .sub-card-light-name { font-size: 12px; font-weight: 500; color: var(--slate); }
  .sub-card-light-price { font-size: 12px; color: var(--teal); font-weight: 500; }

  .gallery-section { background: var(--cream); padding: 80px 24px; }
  .gallery-grid { display: grid; grid-template-columns: 1fr; gap: 20px; margin-top: 40px; }
  .gallery-item {
    border-radius: 16px; overflow: hidden; height: 300px;
    box-shadow: 0 8px 24px rgba(0,0,0,0.08);
    position: relative; cursor: pointer;
    transition: all 0.3s ease;
  }
  .gallery-item:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,0.12); }
  .gallery-item img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s ease; }
  .gallery-item:hover img { transform: scale(1.06); }
  .gallery-overlay {
    position: absolute; inset: 0; background: rgba(43,74,84,0.7);
    display: flex; align-items: center; justify-content: center;
    opacity: 0; transition: opacity 0.3s ease;
  }
  .gallery-item:hover .gallery-overlay { opacity: 1; }
  .gallery-text { color: var(--white); text-align: center; }
  .gallery-text h3 { font-family: var(--serif); font-size: 24px; color: var(--sand); margin-bottom: 6px; }
  .gallery-text p { font-size: 13px; color: rgba(255,255,255,0.8); }

  .courses { background: var(--cream); }
  .course-cards { display: grid; grid-template-columns: 1fr; gap: 20px; margin-top: 40px; }
  .course-card { border-radius: 18px; overflow: hidden; border: 1px solid rgba(43,74,84,0.1); background: var(--white); transition: all 0.3s; box-shadow: 0 4px 16px rgba(0,0,0,0.05); position: relative; }
  .course-card:hover { transform: translateY(-6px); box-shadow: 0 12px 32px rgba(43,74,84,0.12); }
  
  .course-media {
    width: 100%; height: 280px; background: linear-gradient(135deg, var(--teal-lt), var(--sand-lt));
    overflow: hidden; position: relative;
  }
  .course-media video {
    width: 100%; height: 100%; object-fit: cover; opacity: 0.8;
  }
  
  .course-header { padding: 22px 24px 16px; border-bottom: 1px solid rgba(43,74,84,0.06); }
  .course-type { font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; font-weight: 500; margin-bottom: 10px; }
  .course-type.online { color: var(--teal); }
  .course-type.presencial { color: var(--terra); }
  .course-title { font-family: var(--serif); font-size: 21px; font-weight: 400; color: var(--slate); line-height: 1.25; margin-bottom: 6px; }
  .course-sub { font-size: 13px; color: var(--muted); }
  .course-badge { display: inline-block; padding: 3px 10px; border-radius: 50px; font-size: 10px; font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase; margin-left: 8px; vertical-align: middle; }
  .badge-online { background: var(--teal-lt); color: var(--slate); }
  .badge-presencial { background: var(--terra-lt); color: var(--terra); }
  .course-body { padding: 16px 24px 22px; }
  .course-modules { list-style: none; margin-bottom: 20px; }
  .course-modules li { font-size: 13px; color: var(--muted); padding: 6px 0; display: flex; gap: 8px; align-items: flex-start; border-bottom: 1px solid rgba(43,74,84,0.05); }
  .course-modules li:last-child { border-bottom: none; }
  .course-modules li::before { content: ''; width: 4px; height: 4px; border-radius: 50%; background: var(--teal); flex-shrink: 0; margin-top: 7px; }
  .course-footer { display: flex; align-items: center; justify-content: space-between; gap: 14px; flex-wrap: wrap; }
  .course-price { font-size: 13px; color: var(--muted); }
  .course-price strong { display: block; font-size: 18px; color: var(--slate); font-weight: 500; margin-top: 2px; }
  .course-btn { padding: 12px 24px; border-radius: 50px; font-size: 13px; font-weight: 500; border: none; cursor: pointer; transition: all 0.2s; white-space: nowrap; }
  .cbtn-online { background: var(--teal); color: var(--white); }
  .cbtn-online:hover { background: #3a7273; transform: translateY(-2px); }
  .cbtn-presencial { background: var(--terra); color: var(--white); }
  .cbtn-presencial:hover { background: #8B4423; transform: translateY(-2px); }

  .ritual { background: var(--slate); }
  .ritual .section-label { color: var(--teal-lt); }
  .ritual .section-title { color: var(--white); }
  .ritual .section-body { color: rgba(255,255,255,0.55); }
  .steps { display: flex; flex-direction: column; gap: 0; margin-top: 36px; position: relative; }
  .steps::before { content: ''; position: absolute; left: 19px; top: 20px; bottom: 20px; width: 1px; background: rgba(200,224,224,0.15); }
  .step { display: flex; gap: 18px; padding-bottom: 30px; opacity: 0; animation: fadeUp 0.7s ease forwards; }
  .step:nth-child(1) { animation-delay: 0.1s; }
  .step:nth-child(2) { animation-delay: 0.2s; }
  .step:nth-child(3) { animation-delay: 0.3s; }
  .step:last-child { padding-bottom: 0; }
  .step-num { width: 40px; height: 40px; border-radius: 50%; background: rgba(200,224,224,0.1); border: 1px solid rgba(200,224,224,0.22); display: flex; align-items: center; justify-content: center; font-family: var(--serif); font-size: 16px; color: var(--teal-lt); flex-shrink: 0; transition: all 0.3s; }
  .step:hover .step-num { background: rgba(200,224,224,0.2); transform: scale(1.1); }
  .step-content { padding-top: 8px; }
  .step-title { font-family: var(--serif); font-size: 18px; font-weight: 400; color: var(--white); margin-bottom: 4px; }
  .step-desc { font-size: 13px; color: rgba(255,255,255,0.5); line-height: 1.65; }

  .testimonials { background: var(--sand-lt); }
  .testimonials .section-label { color: var(--terra); }
  
  .testi-grid {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-top: 30px;
  }

  .testi-card {
    background: var(--white);
    border-radius: 16px;
    padding: 24px;
    border: 1px solid rgba(212,169,122,0.18);
    transition: all 0.3s;
    box-shadow: 0 2px 8px rgba(0,0,0,0.04);
  }

  .testi-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 20px rgba(212,169,122,0.2);
  }

  .testi-stars {
    color: var(--sand);
    font-size: 12px;
    letter-spacing: 2px;
    margin-bottom: 12px;
  }

  .testi-quote {
    font-family: var(--serif);
    font-size: 17px;
    font-weight: 300;
    font-style: italic;
    color: var(--slate);
    line-height: 1.6;
    margin-bottom: 16px;
  }

  .testi-author {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .testi-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--teal), var(--sand));
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    font-weight: 600;
    color: var(--white);
    flex-shrink: 0;
    box-shadow: 0 4px 12px rgba(74, 139, 140, 0.3);
  }

  .testi-name {
    font-size: 13px;
    font-weight: 500;
    color: var(--slate);
  }

  .testi-role {
    font-size: 12px;
    color: var(--muted);
  }

  .google-reviews-title {
    font-size: 10px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--terra);
    margin-bottom: 20px;
    margin-top: 40px;
    font-weight: 500;
  }

  .google-reviews-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
    margin-top: 30px;
  }

  .google-review-card {
    background: var(--white);
    border-radius: 16px;
    padding: 24px;
    border: 1px solid rgba(212,169,122,0.18);
    transition: all 0.3s;
    box-shadow: 0 2px 8px rgba(0,0,0,0.04);
  }

  .google-review-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 20px rgba(212,169,122,0.2);
  }

  .google-stars {
    color: var(--sand);
    font-size: 12px;
    letter-spacing: 2px;
    margin-bottom: 12px;
  }

  .google-quote {
    font-family: var(--serif);
    font-size: 15px;
    font-weight: 300;
    color: var(--slate);
    line-height: 1.6;
    margin-bottom: 16px;
  }

  .google-author {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .google-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--terra), var(--sand));
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    font-weight: 600;
    color: var(--white);
    flex-shrink: 0;
    box-shadow: 0 4px 12px rgba(160, 82, 45, 0.3);
  }

  .google-name {
    font-size: 13px;
    font-weight: 500;
    color: var(--slate);
  }

  .final-cta { background: var(--cream); text-align: center; padding: 80px 24px; }
  .final-cta .section-title { margin-bottom: 12px; }
  .final-cta .section-body { margin: 0 auto 40px; text-align: center; }
  .cta-group { display: flex; flex-direction: column; gap: 14px; align-items: center; }
  .cta-primary { display: inline-block; background: var(--slate); color: var(--white); font-size: 15px; font-weight: 500; padding: 18px 44px; border-radius: 50px; transition: all 0.3s; width: 100%; max-width: 320px; text-align: center; box-shadow: 0 8px 20px rgba(43,74,84,0.2); }
  .cta-primary:hover { background: var(--slate-lt); transform: translateY(-3px); box-shadow: 0 12px 28px rgba(43,74,84,0.3); }
  .cta-secondary { display: inline-block; background: transparent; color: var(--slate); font-size: 14px; padding: 14px 38px; border-radius: 50px; border: 2px solid rgba(43,74,84,0.28); transition: all 0.3s; width: 100%; max-width: 320px; text-align: center; }
  .cta-secondary:hover { background: rgba(43,74,84,0.05); border-color: var(--slate); transform: translateY(-2px); }
  .cta-wpp { display: inline-flex; align-items: center; gap: 8px; margin-top: 16px; font-size: 13px; color: var(--teal); font-weight: 500; transition: all 0.3s; }
  .cta-wpp:hover { color: var(--slate); transform: translateX(4px); }
  .cta-wpp svg { width: 16px; height: 16px; fill: currentColor; }

  footer { background: var(--slate); padding: 40px 24px 100px; text-align: center; }
